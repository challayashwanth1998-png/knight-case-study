# ──────────────────────────────────────────────
# Knight Insurance — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ── Database ─────────────────────────────────
DATABASE_URL=sqlite:///./data/knight_insurance.db

# ── AI Engine (Google Gemini) ────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── AWS (Optional — for S3 storage) ──────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET_NAME=knight-insurance-docs

# ── AWS Bedrock (Optional — alternative AI) ──
BEDROCK_API_KEY=your-bedrock-api-key

# ── Email Intake (IMAP) ─────────────────────
IMAP_HOST=mail.privateemail.com
IMAP_PORT=993
IMAP_USERNAME=your-email@domain.com
IMAP_PASSWORD=your-email-password

# ── Application ─────────────────────────────
DEBUG=False
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Frontend ────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
